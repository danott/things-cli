#!/usr/bin/env ruby
# frozen_string_literal: true

# things-workspace - set up and open a Claude workspace for a Things task
#
# Usage:
#   things-workspace <title-or-id>
#
# What it does:
#   1. Ensures a companion folder exists (via things-folder)
#   2. Looks up the resolved item from the folder
#   3. Prompts for a claude config environment (via claudenv)
#   4. Writes CLAUDE.md with task context
#   5. Sets up default permissions
#   6. Appends a snapshot to things.md
#   7. Opens the workspace (tmux window or Ghostty tab)

require "json"
require "fileutils"
require "shellwords"

THINGS_FOLDER = File.join(__dir__, "things-folder")

def main
  id = ARGV.first
  abort "Usage: things-workspace <title-or-id>" unless id

  # 1. Look up the original item (before folder resolution)
  original = things_json("todo", "show", id) || things_json("project", "show", id)
  abort "Error: could not find \"#{id}\" in Things" unless original

  # 2. Ensure companion folder (things-folder handles todo→project resolution)
  path = `#{THINGS_FOLDER.shellescape} init #{id.shellescape}`.strip
  abort "Error: could not resolve folder for \"#{id}\"" if path.empty? || !File.directory?(path)

  # 3. Parse kind and ID from folder name, look up the folder's item
  basename = File.basename(path)
  prefix = basename[0]
  folder_kind = prefix == "p" ? "project" : "todo"
  folder_id = basename.split("-").last

  folder_item = things_json(folder_kind, "show", folder_id)
  abort "Error: could not look up #{folder_kind} #{folder_id}" unless folder_item

  # 4. Append snapshot — always log the original item that launched this
  snapshot = `things todo show #{original["id"].shellescape} --md 2>/dev/null`.strip
  if snapshot.empty?
    snapshot = `things project show #{original["id"].shellescape} --md 2>/dev/null`.strip
  end
  unless snapshot.empty?
    File.open(File.join(path, "things.md"), "a") do |f|
      f.puts("---")
      f.puts(snapshot)
      f.puts
    end
  end

  # 5. Write CLAUDE.md
  write_claude_md(path, folder_kind, folder_item, original)

  # 5. Set up config environment (claudenv handles .envrc + direnv allow)
  ensure_envrc(path)

  # 6. Write default permissions
  write_permissions(path)

  # 7. Open
  open_workspace(path)
end

def things_json(*args)
  out = `things #{args.map(&:shellescape).join(" ")} --json 2>/dev/null`
  $?.success? ? JSON.parse(out) : nil
end

def write_claude_md(path, folder_kind, folder_item, original)
  sections = []

  # If the original is a todo inside a project, lead with the todo
  if original["id"] != folder_item["id"]
    sections << "# #{original["name"]}\n\nThings ID: #{original["id"]}\nProject: #{folder_item["name"]} (#{folder_item["id"]})"
  else
    sections << "# #{folder_item["name"]}\n\nThings ID: #{folder_item["id"]}"
  end

  # Check both items for Slack context
  [original, folder_item].uniq { |d| d["id"] }.each do |data|
    notes = data["notes"]
    next unless notes && !notes.strip.empty?
    slack_line = notes.lines.first&.strip
    next unless slack_line&.match?(%r{^https://.*\.slack\.com/archives/})
    match = slack_line.match(%r{/archives/([^/]+)/p(\d+)})
    next unless match
    channel_id = match[1]
    raw_ts = match[2]
    message_ts = "#{raw_ts[0..-7]}.#{raw_ts[-6..]}"
    sections << <<~MD.strip
      ## Slack context

      Read this Slack thread using slack_read_thread (channel_id: #{channel_id}, message_ts: #{message_ts}).
      Source: #{slack_line}
    MD
  end

  # CLI instructions for the current focus
  if original["id"] != folder_item["id"]
    sections << <<~MD.strip
      ## Things CLI

      Current todo:
      ```bash
      things todo show #{original["id"]} --json
      things todo update #{original["id"]} --append-notes "..."
      things todo complete #{original["id"]}
      ```

      Parent project:
      ```bash
      things project show #{folder_item["id"]} --json
      ```

      The `things.md` file contains snapshots of todos launched in this workspace (last line is latest).
    MD
  else
    sections << <<~MD.strip
      ## Things CLI

      ```bash
      things #{folder_kind} show #{folder_item["id"]} --json
      things #{folder_kind} update #{folder_item["id"]} --append-notes "..."
      things #{folder_kind} complete #{folder_item["id"]}
      ```

      The `things.md` file contains snapshots of this task (last line is latest).
    MD
  end

  File.write(File.join(path, "CLAUDE.md"), sections.join("\n\n") + "\n")
end

def ensure_envrc(path)
  envrc = File.join(path, ".envrc")
  return if File.exist?(envrc)
  Dir.chdir(path) { system("claudenv") }
end

def write_permissions(path)
  settings_dir = File.join(path, ".claude")
  settings_file = File.join(settings_dir, "settings.json")
  return if File.exist?(settings_file)

  FileUtils.mkdir_p(settings_dir)
  settings = {
    "permissions" => {
      "allow" => [
        "Bash(things *)",
        "Bash(git *)",
        "Bash(gh *)",
      ]
    }
  }
  File.write(settings_file, JSON.pretty_generate(settings) + "\n")
end

def open_workspace(path)
  name = File.basename(path)

  if ENV["TMUX"]
    # Select existing window by name, or create a new one
    unless system("tmux", "select-window", "-t", ":#{name}", [:out, :err] => File::NULL)
      system("tmux", "new-window", "-c", path, "-n", name)
    end
  elsif ENV["TERM_PROGRAM"] == "ghostty"
    # Try to find and focus an existing tab with this path, or open a new one
    script = <<~APPLESCRIPT
      tell application "System Events"
        tell process "ghostty"
          set frontmost to true
          set found to false
          repeat with w in windows
            repeat with t in (UI elements of w whose role is "AXTabGroup")
              repeat with tab in radio buttons of t
                if name of tab contains "#{name}" then
                  perform action "AXPress" of tab
                  set found to true
                  exit repeat
                end if
              end repeat
              if found then exit repeat
            end repeat
            if found then exit repeat
          end repeat
          if not found then
            keystroke "t" using command down
            delay 0.3
            keystroke "cd #{path.shellescape} && clear\r"
          end if
        end tell
      end tell
    APPLESCRIPT
    system("osascript", "-e", script)
  else
    system("open", path)
  end
end

main
